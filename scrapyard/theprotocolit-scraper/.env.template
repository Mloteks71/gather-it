# %2f is the URL-encoded form of "/"
RABBITMQ_URL=amqp://<user>:<password>@<host>:<port>/%2f
RABBITMQ_EXCHANGE=mapping_exchange
RABBITMQ_ROUTING_KEY=mapping

SCHEDULER_URL=http://<scheduler-host>:8101/register
SCRAPER_ENDPOINT=http://<this-host>:8802/scrap

# Page number is appended to this URL
API_URL=https://apus-api.theprotocol.it/offers/_search?orderby.field=Relevance&pageSize=50&pageNumber=

# Auth headers required by the theprotocol.it API; grab fresh values from a
# browser session when they expire
TP_XSRF_TOKEN=<x-xsrf-token header value>
TP_COOKIE=<Cookie header value>
