  "query": "SELECT\n            w.id,\n            w.worker_id,\n            w.scheduled_time,\n            wr.external_id,\n            wr.endpoint,\n            wr.interval\n        FROM work w\n        JOIN worker wr ON wr.id = w.worker_id\n        WHERE w.scheduled_time <= NOW()",
