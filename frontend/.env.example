# Base URL for the JobReadApi service.
# Leave unset to use the relative "/api" path, which the Vite dev server
# proxies to VITE_API_PROXY_TARGET (see vite.config.ts).
# VITE_API_BASE_URL=http://localhost:8002/api

# Where the Vite dev server proxies "/api" requests during `npm run dev`.
# Defaults to http://localhost:8002 (the Docker port mapping for JobReadApi).
# For a local `dotnet run`, use http://localhost:5139 instead.
# VITE_API_PROXY_TARGET=http://localhost:8002
